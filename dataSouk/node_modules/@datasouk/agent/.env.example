# Copier vers apps/agent/.env — chargé automatiquement au démarrage (npm run dev:agent)
INNOVA_DB_TYPE=mssql
INNOVA_MSSQL_SERVER=localhost\SQLEXPRESS
INNOVA_MSSQL_DB=InnovaPOS
INNOVA_MSSQL_USER=root
INNOVA_MSSQL_PASSWORD=root
INNOVA_SQLITE_PATH=C:/InnovaSoft/data/innova.db
ANONYMIZE_SALT=change_me_to_32_random_chars_minimum
CLOUD_API_URL=https://api.datasouk.tn
# Obtenue via POST /api/v1/register sur le cloud (voir GET http://localhost:3456/registration-info)
CLOUD_API_KEY=
LOCAL_PORT=3456
