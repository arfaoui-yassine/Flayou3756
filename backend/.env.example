# LLM Configuration (Optional - system works without it)
# The backend uses heuristics if LLM is not configured
# With LLM: Enhanced natural language understanding and storytelling

# Blaze AI API (or any OpenAI-compatible endpoint)
BLAZE_API_KEY=your_api_key_here
BLAZE_BASE_URL=https://blazeai.boxu.dev/api/
BLAZE_MODEL=qwen3.6-plus

# Alternative: OpenAI
# BLAZE_API_KEY=sk-...
# BLAZE_BASE_URL=https://api.openai.com/v1/
# BLAZE_MODEL=gpt-4

# Alternative: Local LLM (Ollama, LM Studio, etc.)
# BLAZE_API_KEY=dummy
# BLAZE_BASE_URL=http://localhost:11434/v1/
# BLAZE_MODEL=llama3
